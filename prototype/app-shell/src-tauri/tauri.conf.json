{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maple",
  "version": "0.1.23",
  "identifier": "com.ahnchulwoo.maple",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maple",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$HOME/**/.aiwiki/**",
          "$HOME/**/.studywiki/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "publisher": "chulwoo ahn",
    "copyright": "Copyright 2026 chulwoo ahn. All rights reserved.",
    "category": "Education",
    "shortDescription": "Build a local AI-maintained wiki from your sources.",
    "longDescription": "Maple helps learners, personal archivists, and small teams compile local source folders into a maintained, source-grounded wiki using their own AI subscriptions.",
    "resources": {
      "../../operation-runner/package.json": "operation-runner/package.json",
      "../../operation-runner/node_modules": "operation-runner/node_modules",
      "../../operation-runner/src": "operation-runner/src",
      "../../../public-wiki/api": "public-wiki/api",
      "../../../public-wiki/index.html": "public-wiki/index.html",
      "../../../public-wiki/node_modules/argparse": "public-wiki/node_modules/argparse",
      "../../../public-wiki/node_modules/dayjs": "public-wiki/node_modules/dayjs",
      "../../../public-wiki/node_modules/deepmerge": "public-wiki/node_modules/deepmerge",
      "../../../public-wiki/node_modules/dom-serializer": "public-wiki/node_modules/dom-serializer",
      "../../../public-wiki/node_modules/domelementtype": "public-wiki/node_modules/domelementtype",
      "../../../public-wiki/node_modules/domhandler": "public-wiki/node_modules/domhandler",
      "../../../public-wiki/node_modules/domutils": "public-wiki/node_modules/domutils",
      "../../../public-wiki/node_modules/entities": "public-wiki/node_modules/entities",
