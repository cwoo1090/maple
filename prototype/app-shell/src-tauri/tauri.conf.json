{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maple",
  "version": "0.1.1",
  "identifier": "com.ahnchulwoo.maple",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maple",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$HOME/**/.aiwiki/**",
          "$HOME/**/.studywiki/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "publisher": "chulwoo ahn",
    "copyright": "Copyright 2026 chulwoo ahn. All rights reserved.",
    "category": "Education",
    "shortDescription": "Build a local AI-maintained wiki from your sources.",
    "longDescription": "Maple helps learners, personal archivists, and small teams compile local source folders into a maintained, source-grounded wiki using their own AI subscriptions.",
    "resources": {
      "../../operation-runner/package.json": "operation-runner/package.json",
      "../../operation-runner/src": "operation-runner/src"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 185
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 185
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1RUZFRDU4OThCNTY1RjgKUldUNFpiV1lXTzN2RmNBT1RwRkxjb250ZHZCQklwQUNrV1cxYkRhc3lCellhdVY4dmdIUXYyK20K",
      "endpoints": [
        "https://github.com/cwoo1090/maple/releases/latest/download/latest.json"
      ]
    }
  }
}
